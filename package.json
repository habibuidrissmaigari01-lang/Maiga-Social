{
  "name": "maiga-api",
  "version": "1.0.0",
  "description": "API for Maiga Social App",
  "main": "api.js",
  "scripts": {
    "start": "node api.js",
    "dev": "nodemon api.js",
    "build": "npm run css:build && babel public/maiga.js --out-file public/maiga.min.js",
    "css:watch": "tailwindcss -i ./public/css/input.css -o ./public/css/main.css --watch",
    "css:build": "tailwindcss -i ./public/css/input.css -o ./public/css/main.css --minify"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/lib-storage": "^3.1027.0",
    "@getbrevo/brevo": "^2.0.0",
    "@tailwindcss/cli": "^4.2.2",
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "fluent-ffmpeg": "^2.1.2",
    "formidable": "^3.5.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "serverless-http": "^3.2.0",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "wrangler": "^3.114.17"
  }
}
